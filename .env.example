# =============================================
# Global Max Services — Environment Variables
# Add these in Vercel → Settings → Environment Variables
# =============================================

# Supabase (shared project — oschjeuhejqibymdaqxw)
NEXT_PUBLIC_SUPABASE_URL=https://oschjeuhejqibymdaqxw.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Telnyx SMS
TELNYX_API_KEY=your_telnyx_api_key
TELNYX_PHONE_NUMBER=+1XXXXXXXXXX

# Phone number that receives SMS alerts on new form submissions
# Change this to dispatch number later: +16309484754
GMS_NOTIFY_PHONE=+1XXXXXXXXXX

# Admin dashboard password (used as X-Admin-Key header)
# Pick any random string — this IS the login password
GMS_ADMIN_KEY=pick_a_strong_random_string
